# =============================================================
# Planka Stack - Environment Variables
# Copia este ficheiro para .env e preenche os valores.
# =============================================================

# PostgreSQL
POSTGRES_DB=planka
POSTGRES_USER=planka
POSTGRES_PASSWORD=planka

# Planka Secret Key — gera um valor aleatório seguro:
#   openssl rand -hex 64
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_64

# Planka Admin = MCP Agent (criado automaticamente no primeiro boot)
# O primeiro utilizador do Planka é o agente; o MCP usa as mesmas credenciais.
MCP_AGENT_EMAIL=claudinho@planka.local
MCP_AGENT_PASSWORD=CHANGE_ME_strong_password
MCP_AGENT_NAME=claudinho
